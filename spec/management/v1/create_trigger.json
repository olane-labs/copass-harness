{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "create_trigger",
  "description": "Bind an agent to events from a data source. Use `event_type_filter='*'` to fire on every event from the source (cheap when the agent's prompt does the filtering). Set `rate_limit_per_hour` to bound cost — 60 is a safe default during testing.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["agent_slug", "data_source_id"],
    "properties": {
      "agent_slug": { "type": "string" },
      "data_source_id": { "type": "string" },
      "event_type_filter": {
        "type": "string",
        "description": "Dotted namespace e.g. 'slack.message.new', or '*' for wildcard. Defaults to '*' when omitted."
      },
      "filter_config": {
        "type": "object",
        "description": "Flat {key: scalar} match against DataSourceEvent.normalized_fields.",
        "additionalProperties": true
      },
      "rate_limit_per_hour": {
        "type": "integer",
        "minimum": 1
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "required": ["trigger"],
        "properties": {
          "trigger": {
            "type": "object",
            "required": ["trigger_id"],
            "properties": {
              "trigger_id": { "type": "string" },
              "agent_id": { "type": ["string", "null"] },
              "data_source_id": { "type": ["string", "null"] },
              "event_type_filter": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "rate_limit_per_hour": { "type": ["integer", "null"] },
              "created_at": { "type": ["string", "null"], "format": "date-time" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    ]
  },
  "since": "v1.2"
}
