{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "list_trigger_components",
  "description": "Search the active trigger-provider registry. Required before recommending a trigger component to the user — discover the right slug + its configurable_props schema. Filter by `app` slug (e.g. 'slack', 'gmail') and/or free-text `q`. Returns components the user can deploy through `provision_source`.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "app": {
        "type": "string",
        "description": "App slug, e.g. 'slack'."
      },
      "q": {
        "type": "string",
        "description": "Free-text search."
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["components", "count"],
    "properties": {
      "components": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["component_id", "name"],
          "properties": {
            "component_id": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "configurable_props": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            }
          },
          "additionalProperties": true
        }
      },
      "count": { "type": "integer", "minimum": 0 }
    },
    "additionalProperties": false
  },
  "since": "v1"
}
