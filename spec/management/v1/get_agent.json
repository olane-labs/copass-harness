{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "get_agent",
  "description": "Fetch one agent by slug — full system_prompt, tool_allowlist, and model_settings. Use this to answer questions about an agent's configuration before recommending changes.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["slug"],
    "properties": {
      "slug": {
        "type": "string",
        "description": "The agent's slug."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "required": ["agent"],
        "properties": {
          "agent": {
            "type": "object",
            "required": [
              "agent_id",
              "slug",
              "name",
              "system_prompt",
              "tool_allowlist",
              "model_settings",
              "status"
            ],
            "properties": {
              "agent_id": { "type": "string" },
              "slug": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": ["string", "null"] },
              "system_prompt": { "type": "string" },
              "tool_allowlist": {
                "type": "array",
                "items": { "type": "string" }
              },
              "status": { "type": "string" },
              "version": { "type": ["integer", "null"] },
              "created_at": { "type": ["string", "null"], "format": "date-time" },
              "updated_at": { "type": ["string", "null"], "format": "date-time" },
              "model_settings": {
                "type": "object",
                "required": ["backend", "model"],
                "properties": {
                  "backend": { "type": "string", "enum": ["anthropic", "google"] },
                  "model": { "type": "string" },
                  "temperature": { "type": ["number", "null"] },
                  "max_tokens": { "type": ["integer", "null"] },
                  "max_turns": { "type": ["integer", "null"] },
                  "timeout_s": { "type": ["integer", "null"] }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    ]
  },
  "since": "v1"
}
