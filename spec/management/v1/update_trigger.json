{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "update_trigger",
  "description": "Patch an existing trigger's `event_type_filter`, `rate_limit_per_hour`, or `filter_config`. Pass only the fields to change. Pass `null` for `rate_limit_per_hour` to remove the cap, or `null` for `filter_config` to clear it. Use to dial back a chatty trigger or narrow the events that fire.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["trigger_id"],
    "properties": {
      "trigger_id": { "type": "string" },
      "event_type_filter": { "type": "string" },
      "rate_limit_per_hour": {
        "type": ["integer", "null"],
        "minimum": 1
      },
      "filter_config": {
        "type": ["object", "null"],
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "required": ["trigger"],
        "properties": {
          "trigger": {
            "type": "object",
            "required": ["trigger_id"],
            "properties": {
              "trigger_id": { "type": "string" },
              "agent_id": { "type": ["string", "null"] },
              "data_source_id": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "event_type_filter": { "type": ["string", "null"] },
              "rate_limit_per_hour": { "type": ["integer", "null"] },
              "filter_config": {
                "type": ["object", "null"],
                "additionalProperties": true
              },
              "updated_at": { "type": ["string", "null"], "format": "date-time" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    ]
  },
  "since": "v1.2"
}
