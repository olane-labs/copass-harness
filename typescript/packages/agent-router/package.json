{
  "name": "@copass/agent-router",
  "version": "0.3.0",
  "description": "High-level Copass agent SDK \u2014 hosted agent-runtime routing + integrations + one-liner OAuth flow",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "agents",
    "agent-router",
    "oauth",
    "integrations",
    "pipedream"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass-harness.git",
    "directory": "typescript/packages/agent-router"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@copass/core": "^0.3.0"
  },
  "devDependencies": {
    "@copass/core": "^0.3.0",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  }
}
