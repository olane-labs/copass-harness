{
  "name": "@copass/datasource-olane",
  "version": "0.2.5",
  "description": "Olane OS data source driver for Copass — start/stop/status of local Olane OS instances, address book, worlds, and identity management",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "copass",
    "olane",
    "olane-os",
    "p2p",
    "libp2p",
    "datasource"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass-harness.git",
    "directory": "typescript/packages/datasource-olane"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@olane/o-client": "^0.8.19",
    "@olane/o-core": "^0.8.18",
    "@olane/o-node": "^0.8.18",
    "@olane/os": "^0.8.18",
    "fs-extra": "^11.3.4",
    "portfinder": "^1.0.38"
  },
  "peerDependencies": {
    "@copass/core": "^0.2.0"
  },
  "devDependencies": {
    "@copass/core": "^0.2.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  },
  "gitHead": "fb7984c723588558b5fb81ff3651cfa84d12da5d"
}
