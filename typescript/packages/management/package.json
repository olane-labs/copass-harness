{
  "name": "@copass/management",
  "version": "0.1.0",
  "description": "Spec-driven management tool registrar for Copass agents (read-only, Phase 1).",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/mcp": {
      "import": {
        "types": "./dist/adapters/mcp.d.ts",
        "default": "./dist/adapters/mcp.js"
      },
      "require": {
        "types": "./dist/adapters/mcp.d.cts",
        "default": "./dist/adapters/mcp.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/copy-spec.mjs && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint:redaction": "python3 ../../../scripts/lint_redaction.py",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "management",
    "agents",
    "mcp",
    "olane"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@copass/core": "^0.3.7",
    "zod": "^4.3.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@copass/core": "^0.3.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.0"
  },
  "copass": {
    "minSpecVersion": "v1",
    "maxSpecVersion": "v1"
  }
}
