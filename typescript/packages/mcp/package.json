{
  "name": "@copass/mcp",
  "version": "0.3.7",
  "description": "Standalone MCP server for Copass — drop-in discover/interpret/search + Context Window tools for any MCP client (Claude Agent SDK, Claude Code, Claude Desktop, Cursor)",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "copass-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "knowledge-graph",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "agent",
    "rag"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass-harness.git",
    "directory": "typescript/packages/mcp"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@copass/config": "^0.3.1",
    "@copass/management": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.0"
  },
  "peerDependencies": {
    "@copass/core": "^0.3.0"
  },
  "devDependencies": {
    "@copass/core": "^0.3.8",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  },
  "gitHead": "fb7984c723588558b5fb81ff3651cfa84d12da5d"
}
