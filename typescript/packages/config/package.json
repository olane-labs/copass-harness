{
  "name": "@copass/config",
  "version": "0.3.1",
  "description": "Canonical tool descriptions, parameter descriptions, and system prompts shared across every @copass/* adapter. Single source of truth for LLM-facing copy.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "config",
    "tool-descriptions",
    "system-prompts",
    "llm"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass-harness.git",
    "directory": "typescript/packages/config"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  },
  "gitHead": "fb7984c723588558b5fb81ff3651cfa84d12da5d"
}
