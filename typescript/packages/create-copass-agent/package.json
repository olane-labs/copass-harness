{
  "name": "create-copass-agent",
  "version": "0.4.1",
  "description": "Scaffold a Copass-backed agent: Hono + Vercel AI SDK + Claude + Context Window, ready to edit and deploy.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "bin": {
    "create-copass-agent": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "template/**/*",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "create",
    "starter",
    "agent",
    "scaffold",
    "hono",
    "vercel-ai-sdk",
    "claude"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass.git",
    "directory": "typescript/packages/create-copass-agent"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  },
  "gitHead": "fb7984c723588558b5fb81ff3651cfa84d12da5d"
}
