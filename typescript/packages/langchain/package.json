{
  "name": "@copass/langchain",
  "version": "0.5.0",
  "description": "LangChain tool adapters for Copass — drop-in discover/interpret/search tools for LangChain agents",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copass",
    "knowledge-graph",
    "langchain",
    "agent",
    "tools",
    "rag"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass.git",
    "directory": "typescript/packages/langchain"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@copass/config": "^0.4.2"
  },
  "peerDependencies": {
    "@copass/core": "^0.4.0",
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "@langchain/langgraph": {
      "optional": true
    }
  },
  "devDependencies": {
    "@copass/core": "^0.5.0",
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph": "^1.2.0",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.0"
  },
  "gitHead": "fb7984c723588558b5fb81ff3651cfa84d12da5d"
}
