{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "npm",
  "command": {
    "version": {
      "conventionalCommits": true,
      "message": "chore(release): publish",
      "createRelease": "github",
      "allowBranch": ["main", "release/*"],
      "ignoreChanges": [
        "**/*.md",
        "**/test/**",
        "**/*.test.ts",
        "**/tsconfig*.json",
        "**/vitest.config.ts"
      ],
      "push": true
    },
    "publish": {
      "conventionalCommits": true,
      "registry": "https://registry.npmjs.org/",
      "access": "public",
      "verifyAccess": false
    }
  }
}
